<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.atu.healthlog.studenthealthweatherlog.AuthController" style="-fx-background-color: #f6f7ff;">
    <center>
        <StackPane BorderPane.alignment="CENTER" style="-fx-padding: 40;">
        <VBox spacing="16" alignment="CENTER" prefWidth="440" maxWidth="440" style="-fx-background-color: white; -fx-padding: 34; -fx-background-radius: 16; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 12, 0, 0, 6);">
            <Label text="Welcome" styleClass="headline-md">
                <font>
                    <Font name="Manrope" size="26" />
                </font>
            </Label>
            <Label text="Sign in to continue or create a new account." styleClass="body-md" />

            <TabPane fx:id="authTabPane" tabClosingPolicy="UNAVAILABLE" prefWidth="360">
                <tabs>
                    <Tab text="Sign In" />
                    <Tab text="Sign Up" />
                </tabs>
            </TabPane>

            <VBox spacing="10" alignment="CENTER" prefWidth="360" maxWidth="360">
                <TextField fx:id="nameField" promptText="Full name" prefWidth="360" />
                <Label fx:id="nameHelpLabel" text="Name is required for sign up." style="-fx-text-fill: #70767a; -fx-font-size: 0.85em;" />
                <TextField fx:id="emailField" promptText="Email" prefWidth="360" />
                <PasswordField fx:id="passwordField" promptText="Password" prefWidth="360" />

                <HBox spacing="10" alignment="CENTER">
                    <Button fx:id="signInBtn" text="Sign In" onAction="#handleSignIn" styleClass="button-primary" style="-fx-background-color: #005faf; -fx-text-fill: white; -fx-padding: 10 22; -fx-font-weight: bold;" />
                    <Button fx:id="signUpBtn" text="Create Account" onAction="#handleSignUp" styleClass="button-secondary" style="-fx-background-color: #d4e3ff; -fx-text-fill: #005faf; -fx-padding: 10 22; -fx-font-weight: bold;" />
                </HBox>
            </VBox>

            <Label fx:id="statusLabel" text="" />
        </VBox>
        </StackPane>
    </center>
</BorderPane>
