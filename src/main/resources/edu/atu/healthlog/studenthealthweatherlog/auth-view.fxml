<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.atu.healthlog.studenthealthweatherlog.AuthController">
    <center>
        <StackPane BorderPane.alignment="CENTER" style="-fx-padding: 40;">
        <VBox spacing="16" alignment="CENTER" prefWidth="440" maxWidth="440" styleClass="card auth-card">
            <Label text="Welcome" styleClass="headline-md">
                <font>
                    <Font name="Manrope" size="26" />
                </font>
            </Label>
            <Label fx:id="subtitleLabel" text="Sign in to continue." styleClass="body-md" />

            <TabPane fx:id="authTabPane" tabClosingPolicy="UNAVAILABLE" prefWidth="360">
                <tabs>
                    <Tab text="Sign In" />
                    <Tab text="Sign Up" />
                </tabs>
            </TabPane>

            <VBox spacing="10" alignment="CENTER" prefWidth="360" maxWidth="360">
                <TextField fx:id="nameField" promptText="Full name" prefWidth="360" />
                <Label fx:id="nameHelpLabel" text="Name is required for sign up." styleClass="body-md" />
                <TextField fx:id="emailField" promptText="Email" prefWidth="360" />
                <PasswordField fx:id="passwordField" promptText="Password" prefWidth="360" />

                <HBox spacing="10" alignment="CENTER">
                    <Button fx:id="signInBtn" text="Sign In" onAction="#handleSignIn" styleClass="button-primary" />
                    <Button fx:id="signUpBtn" text="Create Account" onAction="#handleSignUp" styleClass="button-secondary" />
                </HBox>
            </VBox>

            <Label fx:id="statusLabel" text="" />
        </VBox>
        </StackPane>
    </center>
</BorderPane>
